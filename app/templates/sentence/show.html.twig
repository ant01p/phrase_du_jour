{% extends 'base.html.twig' %}

{% block title %}La phrase du jour{% endblock %}

{% block body %}
    <div class="container mt-4">

        <h2 class="text-center fw-bold mb-4">La phrase du jour</h2>

        <div class="row justify-content-center">
            <div class="col-md-12">

                <div class="card border-dark">
                    <div class="card-header bg-{{ sentence.category.color }} text-end">
                        <span class="badge rounded-pill bg-{{ sentence.category.color }} ">
                            {{ sentence.category.name }}
                        </span>
                    </div>

                    <div class="card-body bg-{{ sentence.category.color }}">
                        <p class="fw-bold mb-2">
                            {{ sentence.createdAt|date('d/m/Y') }}
                        </p>
                        <p class="mb-0 small">
                            {{ sentence.content }}
                        </p>
                    </div>

                    <div class="card-footer bg-{{ sentence.category.color }} text-end py-1">
                        {% if app.user %}
                            <a href="{{ path('app_sentence_like', {id: sentence.id, token_csrf: csrf_token('like-sentence' ~ sentence.id)}) }}" 
                                class="btn btn-link p-0 text-decoration-none fw-bold text-body px-1">
                                👍🏻{{ sentence.likes }}
                            </a>
                        {% else %}
                            <span class="fw-bold text-body px-1">
                                👍🏻 {{ sentence.likes }}
                            </span>
                        {% endif %}
                    </div>
                </div>

                <h3 class="mt-3">Commentaires</h3>

                {% if app.user and commentForm is not null %}
                    {{ form_start(commentForm) }}
                    {{ form_widget(commentForm) }}
                    <button type="submit" class="btn btn-primary mb-3">Commenter</button>
                    {{ form_end(commentForm) }}
                {% endif %}

                {% if comments is empty %}
                    <p>Soyez le premier à commenter !</p>
                {% endif %}

                {% for comment in comments %}
                    <div class="mb-3">
                        <strong>{{ comment.author.username }}</strong>
                        <small class="text-body-secondary">
                            (le {{ comment.createdAt|date('d/m/Y à H:i:s') }}) :
                        </small>
                        <div>{{ comment.content }}</div>
                    </div>
                {% endfor %}
                
            </div>
        </div>

    </div>
{% endblock %}