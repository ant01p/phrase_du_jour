{% extends 'base.html.twig' %}

{% block title %}Log in!{% endblock %}

{% block body %}
    <div class="container mt-4">

        <h1 class="mb-4">Connexion</h1>

        <form method="post">
            {% if error %}
                <div class="alert alert-danger">Identifiants invalides</div>
            {% endif %}

            {% if app.user %}
                <div class="mb-3">
                    Vous etes connecté en tant que : {{ app.user.userIdentifier }}, <a href="{{ logout_path() }}">Déconnexion</a>
                </div>
            {% endif %}

            <label for="username" class="form-label">Pseudo</label>
            <input type="text" value="{{ last_username }}" name="_username" id="username" class="form-control mb-3" autocomplete="username" required autofocus>
            <label for="password" class="form-label">Mot de passe</label>
            <input type="password" name="_password" id="password" class="form-control mb-3" autocomplete="current-password" required>
            <input type="hidden" name="_csrf_token" data-controller="csrf-protection" value="{{ csrf_token('authenticate') }}">

            {#
                Uncomment this section and add a remember_me option below your firewall to activate remember me functionality.
                See https://symfony.com/doc/current/security/remember_me.html

                <div class="checkbox mb-3">
                    <input type="checkbox" name="_remember_me" id="_remember_me">
                    <label for="_remember_me">Remember me</label>
                </div>
            #}

            <button class="btn btn-primary" type="submit">
                Connexion
            </button>
        </form>
    </div>
{% endblock %}
